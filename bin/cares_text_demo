#!/usr/bin/env bash
#
# Demo: a superseded library version flipping from present to absent in aws-prod.
#
# c-ares (a curl dependency) was bumped 1.34.6-r0 -> 1.34.8-r0 in the saver
# service. In aws-prod, saver ran c-ares 1.34.6-r0 from 2026-07-09 until the
# newer build was promoted on 2026-07-12, superseding it. Querying the superseded
# version over a range that extends just beyond that window shows saver present
# for the version's lifetime, then absent once it was superseded.
set -euo pipefail

show_help() {
  cat <<'EOF'
Usage: bin/cares_text_demo [-h]

Runs sbom-package-history against the live cyber-dojo aws-prod environment for a
superseded library version (c-ares 1.34.6-r0 in saver), showing the
present-then-absent flip. Prints a dot per Kosli CLI call as it runs, and uses a
throwaway read-only API token.

Options:
  -h    Show this help

Example:
  bin/cares_text_demo
EOF
}

if [ "${1:-}" = "-h" ]; then
  show_help
  exit 0
fi

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Overview of what the tool does and its flags, printed from its own --help.
"${here}/sbom-package-history" --help

cat <<'EOF'

This demo searches cyber-dojo's Kosli aws-prod environment for:
  library:  c-ares  1.34.6-r0   (a curl dependency, since superseded by 1.34.8-r0)
  from:     2026-07-09
  to:       2026-07-13

EOF
echo

"${here}/sbom-package-history" \
  --package c-ares@1.34.6-r0 \
  --from 2026-07-09 \
  --to   2026-07-13 \
  --environment aws-prod \
  --api-token demo-read-only-throwaway \
  --progress \
  | "${here}/report_to_text"
