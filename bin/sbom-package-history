#!/usr/bin/env python3
"""Thin entry point for the sbom-package-history CLI.

Adds the repo root to sys.path so the sbom_package_history package imports, then
delegates to its cli.main(). Run with -h for usage and an example.
"""
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), ".."))

from sbom_package_history.cli import main

sys.exit(main())
